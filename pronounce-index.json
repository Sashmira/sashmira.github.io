tml"}, {"ml": "ചായ / കാപ്പി", "r": "Chaaya / Kaapi", "e": "Tea / Coffee", "a": "/audio/chetta-oru-chaaya.mp3", "u": "/how-to-say-tea-and-coffee-in-malayalam.html"}]